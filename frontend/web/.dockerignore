# ── Node modules (installed fresh in Docker) ──────────────────────────────────
node_modules/
**/node_modules/

# ── Next.js build output ──────────────────────────────────────────────────────
.next/
out/

# ── Test files ─────────────────────────────────────────────────────────────────
**/__tests__/
**/*.test.ts
**/*.test.tsx
**/*.spec.ts
**/*.spec.tsx

# ── Source maps ────────────────────────────────────────────────────────────────
**/*.map

# ── OS / editor junk ──────────────────────────────────────────────────────────
**/.DS_Store
**/.idea/
**/.vscode/
**/Thumbs.db

# ── Logs ──────────────────────────────────────────────────────────────────────
**/*.log
**/npm-debug.log*
